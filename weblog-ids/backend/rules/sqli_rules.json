    "severity": "high",
    "description": "Mendeteksi enumerasi versi/konfigurasi database: @@version, version(), v$version"
  },
  {
    "id": "SQLI-007",
    "name": "SQLi Oracle Keyword",
    "attack_type": "SQLi",
    "pattern": "(rownum|dba_users|all_tables|user_tables|v\\$session|banner\\s+from)",
    "severity": "high",
